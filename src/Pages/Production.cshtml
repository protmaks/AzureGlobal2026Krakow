@page
@model ProductionModel
@{
    ViewData["Title"] = "Production";
}
<h1>@ViewData["Title"]</h1>

<p>This page is only visible in Production environment.</p>

<div class="mt-4">
    <h4>Azure Key Vault Configuration</h4>
    <dl class="row">
        <dt class="col-sm-3">Secret Status:</dt>
        <dd class="col-sm-9">
            @if (Model.SecretStatus == "Retrieved successfully")
            {
                <span class="badge bg-success">@Model.SecretStatus</span>
            }
            else if (Model.SecretStatus == "Not configured")
            {
                <span class="badge bg-warning text-dark">@Model.SecretStatus</span>
            }
            else
            {
                <span class="badge bg-danger">@Model.SecretStatus</span>
            }
        </dd>
        
        @if (!string.IsNullOrEmpty(Model.AzureKeyVaultSecret))
        {
            <dt class="col-sm-3">Secret Key:</dt>
            <dd class="col-sm-9">
                <code>@Model.AzureKeyVaultSecret</code>
            </dd>
        }
    </dl>
    
    <div class="alert alert-info" role="alert">
        <strong>Note:</strong> To configure Azure Key Vault, add the following to your configuration:
        <ul class="mb-0 mt-2">
            <li>Set environment variable: <code>AzureKeyVault__SecretKey</code></li>
            <li>Or add to appsettings.json under <code>"AzureKeyVault": { "SecretKey": "your-value" }</code></li>
        </ul>
    </div>
</div>
